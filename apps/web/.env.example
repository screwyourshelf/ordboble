# Ordboble — Environment Variables
#
# Copy this file to .env.local for local development.
# Do not commit .env.local or any file containing secrets.

# Application name (used in UI and meta)
VITE_APP_NAME=Ordboble

# Default locale for the application
# Currently stored for future use — not yet applied to full localization
VITE_DEFAULT_LOCALE=nb

# Base URL for the backend API
# Leave empty to disable API calls (local/prototype mode)
VITE_API_BASE_URL=

# Dev-only: override the cloud/session ID used by contributor and presentation screens.
# Set this to a real cloud ID created via POST /api/clouds for local E2E testing.
# Leave empty to use the mock session (prototype mode).
VITE_CLOUD_ID=
